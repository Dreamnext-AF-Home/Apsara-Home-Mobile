<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Background gradient -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="45"
                android:startColor="#64748b"
                android:endColor="#475569" />
            <corners android:radius="8dp" />
        </shape>
    </item>
</layer-list>
